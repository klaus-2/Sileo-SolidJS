{
	"name": "sileo-solid",
	"version": "0.1.0",
	"description": "An opinionated, physics-based toast notification library for SolidJS.",
	"license": "MIT",
	"author": "Klaus",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/klaus-2/Sileo-SolidJS.git"
	},
	"bugs": {
		"url": "https://github.com/klaus-2/Sileo-SolidJS/issues"
	},
	"homepage": "https://github.com/klaus-2/Sileo-SolidJS#readme",
	"keywords": [
		"solid-js",
		"solidjs",
		"toast",
		"notification",
		"physics",
		"animation",
		"motion",
		"ui",
		"component"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"default": "./dist/index.js"
		},
		"./styles.css": "./dist/styles.css"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"sideEffects": [
		"**/*.css"
	],
	"files": [
		"dist"
	],
	"scripts": {
		"build": "rimraf dist && node build.js",
		"dev": "bunchee --watch",
		"prepublishOnly": "npm run build",
		"clean": "rimraf dist"
	},
	"peerDependencies": {
		"solid-js": ">=1.8"
	},
	"dependencies": {
		"motion": "^12.34.0"
	},
	"devDependencies": {
		"bunchee": "^6.9.4",
		"rimraf": "^6.0.0",
		"solid-js": "^1.9.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
